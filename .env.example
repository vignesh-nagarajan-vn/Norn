# Required for the two Claude calls (adjudicator and reviewer).
# Without this key, Norn falls back to a deterministic heuristic that is
# clearly labeled in the UI. Set this to run the real model passes.
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-opus-4-8.
# IMPORTANT: this must be a model your API key can actually access, or every
# Claude call returns 404 and both the interpretation and the Ask panel fall
# back / error. If the Ask panel reports a failed call, set this to a model
# your key can use (for example claude-sonnet-4-6) and redeploy.
ANTHROPIC_MODEL=claude-opus-4-8

# Optional. Raises NCBI E-utilities rate limits for ClinVar lookups
# from 3 to 10 requests per second. Norn works without it.
NCBI_API_KEY=
